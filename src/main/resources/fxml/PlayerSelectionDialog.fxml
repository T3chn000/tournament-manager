<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="480.0" prefWidth="620.0" spacing="12.0" styleClass="dialog-root" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tournament.ui.controller.PlayerSelectionDialogController">
    <children>
        <Label styleClass="dialog-title" text="Select players" />

        <HBox spacing="8.0">
            <children>
                <TextField fx:id="playerNameField" onAction="#onQuickAddPlayer" promptText="Existing or new player name" HBox.hgrow="ALWAYS" />
                <Button onAction="#onQuickAddPlayer" styleClass="secondary-button" text="Quick add" />
            </children>
        </HBox>

        <HBox spacing="10.0" VBox.vgrow="ALWAYS">
            <children>
                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="section-title" text="Available" />
                        <ListView fx:id="availablePlayersListView" prefHeight="240.0" prefWidth="190.0" VBox.vgrow="ALWAYS" />
                        <Button maxWidth="Infinity" onAction="#onAddSelectedPlayer" styleClass="secondary-button" text="Add selected" />
                    </children>
                </VBox>
                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="section-title" text="Selected" />
                        <ListView fx:id="selectedPlayersListView" prefHeight="115.0" prefWidth="190.0" VBox.vgrow="ALWAYS" />
                        <Button maxWidth="Infinity" onAction="#onRemoveSelectedPlayer" styleClass="danger-button" text="Remove selected" />
                        <Label styleClass="section-title" text="New" />
                        <ListView fx:id="newPlayersListView" prefHeight="95.0" prefWidth="190.0" VBox.vgrow="ALWAYS" />
                        <Button maxWidth="Infinity" onAction="#onRemoveNewPlayer" styleClass="danger-button" text="Remove new" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <Label fx:id="errorLabel" styleClass="error-text" />

        <HBox alignment="CENTER_RIGHT" spacing="8.0">
            <children>
                <Button onAction="#onCancel" text="Cancel" />
                <Button onAction="#onConfirm" styleClass="primary-button" text="Select" />
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
    </padding>
</VBox>
